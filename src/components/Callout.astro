---
interface Props {
  type?: 'exam' | 'danger' | 'tip';
  title?: string;
}
const { type = 'exam', title } = Astro.props;

const labels: Record<string, string> = {
  exam: title ?? 'Exam focus',
  danger: title ?? 'Watch out',
  tip: title ?? 'Memory hook',
};

const icons: Record<string, string> = {
  exam: 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  danger: 'M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z M12 9v4 M12 17h.01',
  tip: 'M9 18h6 M10 22h4 M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.3h6c0-1 .4-1.8 1-2.3A7 7 0 0 0 12 2z',
};
---

<div class={`callout callout--${type}`}>
  <span class="callout__label">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d={icons[type]}></path>
    </svg>
    {labels[type]}
  </span>
  <slot />
</div>
