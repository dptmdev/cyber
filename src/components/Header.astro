---
import ThemeToggle from './ThemeToggle.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="header">
  <a class="header__brand" href={`${base}/`}>
    <svg class="mark" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M12 2 4 5v6c0 4.5 3.2 8.4 8 11 4.8-2.6 8-6.5 8-11V5l-8-3Z"
        fill="currentColor" opacity="0.15"></path>
      <path
        d="M12 2 4 5v6c0 4.5 3.2 8.4 8 11 4.8-2.6 8-6.5 8-11V5l-8-3Z"
        stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
      <path d="m8.5 12 2.4 2.4L15.8 9.5" stroke="currentColor" stroke-width="1.7"
        stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
    <span class="title-text">Cyber Law &amp; Ethics</span>
  </a>

  <div class="header__spacer"></div>

  <ThemeToggle />

  <button
    id="nav-toggle"
    class="btn-icon nav-toggle"
    type="button"
    aria-label="Toggle contents menu"
    aria-controls="sidebar"
    aria-expanded="false"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="4" y1="7" x2="20" y2="7"></line>
      <line x1="4" y1="12" x2="20" y2="12"></line>
      <line x1="4" y1="17" x2="20" y2="17"></line>
    </svg>
  </button>
</header>
