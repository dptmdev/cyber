---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const units = (await getCollection('units')).sort((a, b) => a.data.order - b.data.order);

// current path (strip trailing slash) for active highlighting
const current = Astro.url.pathname.replace(/\/$/, '');
---

<aside class="sidebar" id="sidebar" aria-label="Units">
  <p class="sidebar__title">Syllabus units</p>
  <ul class="sidebar__nav">
    <li>
      <a
        class="sidebar__link"
        href={`${base}/`}
        aria-current={current === base || current === '' ? 'page' : undefined}
      >
        <span class="sidebar__num">·</span>
        <span>Overview</span>
      </a>
    </li>
    {
      units.map((u) => {
        const href = `${base}/units/${u.id}`;
        return (
          <li>
            <a
              class="sidebar__link"
              href={href}
              aria-current={current === href ? 'page' : undefined}
            >
              <span class="sidebar__num">{u.data.order}</span>
              <span>{u.data.title}</span>
            </a>
          </li>
        );
      })
    }
  </ul>
</aside>
