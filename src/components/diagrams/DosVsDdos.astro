---
// DoS (one source) vs DDoS (many sources / botnet) hitting a server.
const bots = [
  [40, 40], [40, 90], [40, 140], [40, 190],
  [95, 55], [95, 125], [95, 185],
];
---
<figure class="figure">
  <svg viewBox="0 0 440 230" role="img" aria-label="DoS uses one attacker, DDoS uses many bots to flood a server">
    <line x1="220" y1="15" x2="220" y2="215" class="dgm-stroke" stroke-width="1" stroke-dasharray="4 4"></line>

    <!-- DoS -->
    <text x="110" y="28" text-anchor="middle" class="dgm-text" font-size="14" font-weight="700">DoS</text>
    <text x="110" y="44" text-anchor="middle" class="dgm-muted" font-size="11">one source · easy to block</text>

    <rect x="35" y="95" width="56" height="36" rx="8" class="dgm-fill-accent"></rect>
    <text x="63" y="118" text-anchor="middle" class="dgm-inv" font-size="11" font-weight="600">Attacker</text>
    <line x1="91" y1="113" x2="150" y2="113" class="dgm-stroke-accent" stroke-width="2.5" marker-end="url(#arrowD)"></line>

    <rect x="152" y="92" width="42" height="42" rx="6" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
    <text x="173" y="117" text-anchor="middle" class="dgm-muted" font-size="16">🖥</text>
    <text x="173" y="150" text-anchor="middle" class="dgm-muted" font-size="10">Server</text>

    <!-- DDoS -->
    <text x="330" y="28" text-anchor="middle" class="dgm-text" font-size="14" font-weight="700">DDoS</text>
    <text x="330" y="44" text-anchor="middle" class="dgm-muted" font-size="11">botnet · hard to filter</text>

    {bots.map(([bx, by]) => (
      <g>
        <rect x={bx + 220} y={by} width="26" height="20" rx="4" class="dgm-fill-surface dgm-stroke" stroke-width="1.3"></rect>
        <line x1={bx + 248} y1={by + 10} x2="388" y2="113" class="dgm-stroke-accent" stroke-width="1.3" opacity="0.7"></line>
      </g>
    ))}
    <text x={40 + 220 - 6} y="218" text-anchor="middle" class="dgm-muted" font-size="10">infected bots</text>

    <rect x="390" y="92" width="42" height="42" rx="6" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
    <text x="411" y="117" text-anchor="middle" class="dgm-muted" font-size="16">🖥</text>
    <text x="411" y="150" text-anchor="middle" class="dgm-muted" font-size="10">Server</text>

    <defs>
      <marker id="arrowD" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0 0 L6 3 L0 6 z" class="dgm-fill-accent"></path>
      </marker>
    </defs>
  </svg>
  <figcaption>DoS floods from a single machine; DDoS coordinates thousands of compromised devices (a botnet) at once.</figcaption>
</figure>
