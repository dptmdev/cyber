---
// The three stages of identity theft.
const steps = [
  { n: 1, t: 'Acquire PII', d: 'breach, phishing, dark web' },
  { n: 2, t: 'Exploit (fraud)', d: 'loans, accounts, refunds' },
  { n: 3, t: 'Consequences', d: 'credit & legal damage' },
];
---
<figure class="figure">
  <svg viewBox="0 0 450 130" role="img" aria-label="Identity theft lifecycle: acquire personal data, commit fraud, victim suffers consequences">
    {steps.map((s, i) => {
      const x = 20 + i * 150;
      return (
        <g>
          <rect x={x} y="34" width="120" height="58" rx="11" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
          <circle cx={x + 22} cy="56" r="13" class="dgm-fill-accent"></circle>
          <text x={x + 22} y="61" text-anchor="middle" class="dgm-inv" font-size="12" font-weight="700">{s.n}</text>
          <text x={x + 44} y="56" class="dgm-text" font-size="11" font-weight="650">{s.t}</text>
          <text x={x + 12} y="82" class="dgm-muted" font-size="9.3">{s.d}</text>
          {i < steps.length - 1 && (
            <line x1={x + 120} y1="63" x2={x + 150} y2="63" class="dgm-stroke-accent dgm-flow" stroke-width="2.2" marker-end="url(#it-arrow)"></line>
          )}
        </g>
      );
    })}
    <defs>
      <marker id="it-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0 0 L6 3 L0 6 z" class="dgm-fill-accent"></path>
      </marker>
    </defs>
  </svg>
  <figcaption>Identity theft runs in three stages — stolen data is turned into fraud, leaving the victim to repair the damage.</figcaption>
</figure>
