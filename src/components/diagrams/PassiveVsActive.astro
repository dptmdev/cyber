---
// Passive vs Active attack — the core distinction examiners ask for.
---
<figure class="figure">
  <svg viewBox="0 0 440 250" role="img" aria-label="Passive attack only observes data, active attack alters or blocks data">
    <!-- divider -->
    <line x1="220" y1="20" x2="220" y2="230" class="dgm-stroke" stroke-width="1" stroke-dasharray="4 4"></line>

    <!-- PASSIVE -->
    <text x="110" y="30" text-anchor="middle" class="dgm-text" font-size="14" font-weight="700">Passive</text>
    <text x="110" y="46" text-anchor="middle" class="dgm-muted" font-size="11">observe only · data unchanged</text>

    <rect x="30" y="70" width="60" height="34" rx="7" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
    <text x="60" y="92" text-anchor="middle" class="dgm-text" font-size="11">Sender</text>
    <rect x="130" y="70" width="60" height="34" rx="7" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
    <text x="160" y="92" text-anchor="middle" class="dgm-text" font-size="11">Receiver</text>

    <line x1="90" y1="87" x2="130" y2="87" class="dgm-stroke-accent" stroke-width="2" marker-end="url(#arrowP)"></line>

    <!-- eavesdropper -->
    <circle cx="110" cy="170" r="20" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></circle>
    <text x="110" y="175" text-anchor="middle" class="dgm-muted" font-size="14">👂</text>
    <line x1="110" y1="104" x2="110" y2="150" class="dgm-stroke" stroke-width="1.5" stroke-dasharray="3 3" marker-end="url(#dotP)"></line>
    <text x="110" y="210" text-anchor="middle" class="dgm-muted" font-size="11">Attacker listens</text>
    <text x="110" y="224" text-anchor="middle" class="dgm-muted" font-size="11">(hard to detect)</text>

    <!-- ACTIVE -->
    <text x="330" y="30" text-anchor="middle" class="dgm-text" font-size="14" font-weight="700">Active</text>
    <text x="330" y="46" text-anchor="middle" class="dgm-muted" font-size="11">alter · inject · block</text>

    <rect x="250" y="70" width="60" height="34" rx="7" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
    <text x="280" y="92" text-anchor="middle" class="dgm-text" font-size="11">Sender</text>
    <rect x="350" y="70" width="60" height="34" rx="7" class="dgm-fill-surface dgm-stroke" stroke-width="1.5"></rect>
    <text x="380" y="92" text-anchor="middle" class="dgm-text" font-size="11">Receiver</text>

    <line x1="310" y1="87" x2="338" y2="87" class="dgm-stroke-accent" stroke-width="2"></line>

    <!-- attacker in the middle modifying -->
    <circle cx="330" cy="170" r="20" class="dgm-fill-accent"></circle>
    <text x="330" y="175" text-anchor="middle" class="dgm-inv" font-size="13" font-weight="700">✎</text>
    <line x1="330" y1="104" x2="330" y2="150" class="dgm-stroke-accent" stroke-width="2" marker-end="url(#arrowA)"></line>
    <line x1="330" y1="150" x2="338" y2="100" class="dgm-stroke-accent" stroke-width="2" marker-end="url(#arrowA)"></line>
    <text x="330" y="210" text-anchor="middle" class="dgm-muted" font-size="11">Attacker changes data</text>
    <text x="330" y="224" text-anchor="middle" class="dgm-muted" font-size="11">(leaves a footprint)</text>

    <defs>
      <marker id="arrowP" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0 0 L6 3 L0 6 z" class="dgm-fill-accent"></path>
      </marker>
      <marker id="arrowA" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0 0 L6 3 L0 6 z" class="dgm-fill-accent"></path>
      </marker>
      <marker id="dotP" markerWidth="6" markerHeight="6" refX="3" refY="3">
        <circle cx="3" cy="3" r="2" class="dgm-fill-surface dgm-stroke"></circle>
      </marker>
    </defs>
  </svg>
  <figcaption>Passive = silently reads the message. Active = steps in and modifies, fakes, or blocks it.</figcaption>
</figure>
