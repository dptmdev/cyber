---
// Attacker hides behind a chain of proxies; target only sees the last proxy's IP.
const nodes = [
  { x: 20,  label: 'Attacker', sub: 'real IP hidden', cls: 'dgm-fill-accent', inv: true },
  { x: 140, label: 'Proxy', sub: 'Brazil', cls: 'dgm-fill-surface' },
  { x: 250, label: 'Proxy', sub: 'Germany', cls: 'dgm-fill-surface' },
  { x: 360, label: 'Target', sub: 'UK', cls: 'dgm-fill-surface' },
];
---
<figure class="figure">
  <svg viewBox="0 0 450 150" role="img" aria-label="Attacker routes through proxies in Brazil and Germany before reaching the UK target">
    {nodes.map((n, i) => (
      <g>
        <rect x={n.x} y="48" width="74" height="40" rx="9" class={`${n.cls} ${n.inv ? '' : 'dgm-stroke'}`} stroke-width="1.5"></rect>
        <text x={n.x + 37} y="66" text-anchor="middle" class={n.inv ? 'dgm-inv' : 'dgm-text'} font-size="11.5" font-weight="650">{n.label}</text>
        <text x={n.x + 37} y="80" text-anchor="middle" class={n.inv ? 'dgm-inv' : 'dgm-muted'} font-size="9">{n.sub}</text>
        {i < nodes.length - 1 && (
          <line x1={n.x + 74} y1="68" x2={nodes[i + 1].x} y2="68" class="dgm-stroke-accent dgm-flow" stroke-width="2.2" marker-end="url(#pc-arrow)"></line>
        )}
      </g>
    ))}
    <text x="397" y="112" text-anchor="middle" class="dgm-muted" font-size="9.5">sees Germany's IP,</text>
    <text x="397" y="124" text-anchor="middle" class="dgm-muted" font-size="9.5">not the attacker</text>
    <defs>
      <marker id="pc-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0 0 L6 3 L0 6 z" class="dgm-fill-accent"></path>
      </marker>
    </defs>
  </svg>
  <figcaption>Chaining proxies across countries means the target logs the last proxy's IP — tracing the real attacker becomes nearly impossible.</figcaption>
</figure>
