---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const units = (await getCollection('units')).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const totalHours = units.reduce((sum, u) => sum + (u.data.lectureHours ?? 0), 0);
---

<BaseLayout title="Cyber Law & Ethics">
  <section class="hero">
    <p class="hero__eyebrow">OEC-CS801B · Open Elective</p>
    <h1>Cyber Law &amp; Ethics — exam notes</h1>
    <p class="hero__lead">
      Simple, complete, exam-ready notes for the whole syllabus. Built to read comfortably
      on a phone or a laptop, with light &amp; dark modes and small diagrams to make the
      tricky bits click.
    </p>
    <div class="hero__meta">
      <span class="chip">{units.length} units</span>
      <span class="chip">{totalHours} lecture hours</span>
      <span class="chip">Definitions · examples · exam points</span>
    </div>
  </section>

  <nav class="unit-grid" aria-label="All units">
    {
      units.map((u) => (
        <a class="unit-card" href={`${base}/units/${u.id}`}>
          <span class="unit-card__num">{String(u.data.order).padStart(2, '0')}</span>
          <span class="unit-card__title">{u.data.title}</span>
          <span class="unit-card__summary">{u.data.summary}</span>
          {u.data.lectureHours && (
            <span class="unit-card__hours">{u.data.lectureHours} lectures</span>
          )}
        </a>
      ))
    }
  </nav>

  <div class="hero" style="margin-top:3rem;">
    <div class="callout callout--tip">
      <span class="callout__label">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18h6 M10 22h4 M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.3h6c0-1 .4-1.8 1-2.3A7 7 0 0 0 12 2z"></path>
        </svg>
        How to use these notes
      </span>
      <p style="margin:0;">
        Each unit gives a clear <strong>definition</strong>, the <strong>key points</strong> to write,
        a <strong>real example</strong>, and a green <strong>“exam focus”</strong> box with the lines
        worth memorising. Skim the one-line answers at the end of each unit the night before.
      </p>
    </div>
  </div>
</BaseLayout>
