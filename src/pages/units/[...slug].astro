---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const units = (await getCollection('units')).sort((a, b) => a.data.order - b.data.order);
  return units.map((unit, i) => ({
    params: { slug: unit.id },
    props: {
      unit,
      prev: units[i - 1] ?? null,
      next: units[i + 1] ?? null,
    },
  }));
}

const { unit, prev, next } = Astro.props;
const { Content } = await render(unit);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={unit.data.title} description={unit.data.summary} active={unit.id} progress>
  <article class="content prose">
    <header class="page-head">
      <div class="tags">
        <span class="tag">Unit {unit.data.order}</span>
        {unit.data.lectureHours && <span class="tag tag--muted">{unit.data.lectureHours} lectures</span>}
      </div>
      <h1>{unit.data.title}</h1>
      <p class="lede">{unit.data.summary}</p>
    </header>
    <Content />
  </article>

  <nav class="pagenav" aria-label="Unit navigation">
    {prev ? (
      <a href={`${base}/units/${prev.id}`}>
        <small>← Previous</small>
        {prev.data.title}
      </a>
    ) : (
      <a class="is-empty" href="#" aria-hidden="true"></a>
    )}
    {next ? (
      <a class="is-next" href={`${base}/units/${next.id}`}>
        <small>Next →</small>
        {next.data.title}
      </a>
    ) : (
      <a class="is-next is-empty" href="#" aria-hidden="true"></a>
    )}
  </nav>
</BaseLayout>
