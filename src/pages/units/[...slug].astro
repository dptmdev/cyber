---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const units = (await getCollection('units')).sort((a, b) => a.data.order - b.data.order);
  return units.map((unit, i) => ({
    params: { slug: unit.id },
    props: {
      unit,
      prev: units[i - 1] ?? null,
      next: units[i + 1] ?? null,
    },
  }));
}

const { unit, prev, next } = Astro.props;
const { Content } = await render(unit);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={unit.data.title} description={unit.data.summary} withSidebar progress>
  <article class="content prose">
    <p class="hero__eyebrow">Unit {unit.data.order}{unit.data.lectureHours ? ` · ${unit.data.lectureHours} lectures` : ''}</p>
    <h1 style="font-size: clamp(1.7rem, 5vw, 2.3rem); line-height:1.15; letter-spacing:-.02em; margin-top:.4rem;">
      {unit.data.title}
    </h1>
    <p class="hero__lead" style="margin-top:.75rem;">{unit.data.summary}</p>
    <hr />
    <Content />
  </article>

  <nav class="pagenav" aria-label="Unit navigation">
    {prev ? (
      <a href={`${base}/units/${prev.id}`}>
        <small>← Previous</small>
        {prev.data.title}
      </a>
    ) : (
      <a class="is-empty" href="#" aria-hidden="true"></a>
    )}
    {next ? (
      <a class="is-next" href={`${base}/units/${next.id}`}>
        <small>Next →</small>
        {next.data.title}
      </a>
    ) : (
      <a class="is-next is-empty" href="#" aria-hidden="true"></a>
    )}
  </nav>
</BaseLayout>
